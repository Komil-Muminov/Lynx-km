import React, { useState } from 'react';
import { QueryProvider, CartProvider } from './providers/index.js';
import { GuestMenu } from '@pages/GuestMenu/index.js';
import { WaiterHome } from '@pages/WaiterHome/index.js';

export const App = () => {
  // Пока сделаем простой переключатель ролей для тестов
  const [role, setRole] = useState<'guest' | 'waiter'>('guest');

  return (
    <QueryProvider>
      <CartProvider>
        <view style={{ flex: 1 }}>
          {/* Временная кнопка смены роли для демонстрации интерфейсов */}
          <view 
            style={{ 
              position: 'absolute', 
              top: 40, 
              right: 16, 
              zIndex: 100, 
              backgroundColor: '#333', 
              padding: 8, 
              borderRadius: 8 
            }} 
            bindtap={() => setRole(role === 'guest' ? 'waiter' : 'guest')}
          >
            <text style={{ color: '#fff', fontSize: 12 }}>Переключить на {role === 'guest' ? 'Официант' : 'Гость'}</text>
          </view>

          {role === 'guest' ? <GuestMenu /> : <WaiterHome />}
        </view>
      </CartProvider>
    </QueryProvider>
  );
};
